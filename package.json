{
  "name": "website-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499",
  "bin": "dist/bin/website-backend.js",
  "scripts": {
    "cdk": "cdk",
    "tsgo": "tsgo",
    "check-types": "tsgo --noEmit",
    "build": "concurrently 'pnpm build:cdk' 'pnpm build:function'",
    "build:cdk": "tsgo",
    "build:function": "cd functions/counter && cargo lambda build --release --arm64",
    "start": "concurrently --kill-others 'pnpm start:cdk' 'pnpm start:function'",
    "start:cdk": "tsgo -w",
    "start:function": "cd functions/counter && cargo lambda watch --env-var TABLE_NAME=Counter",
    "watch": "pnpm start",
    "watch:cdk": "pnpm start:cdk",
    "watch:function": "pnpm start:function",
    "test": "concurrently 'pnpm test:cdk' 'pnpm test:function'",
    "test:cdk": "jest",
    "test:function": "cd functions/counter && cargo test",
    "clean": "concurrently 'pnpm clean:cdk' && 'pnpm clean:function'",
    "clean:cdk": "rimraf cdk.out/ dist/",
    "clean:function": "cd functions/counter && cargo clean",
    "format": "concurrently 'pnpm format:cdk' 'pnpm format:function'",
    "format:cdk": "eslint --fix bin/ lib/ test/ && prettier --write bin/ lib/ test/",
    "format:function": "cd functions/counter && cargo fmt",
    "up": "concurrently 'corepack up && pnpm up:cdk' 'pnpm up:function'",
    "up:cdk": "pnpm update --interactive --latest",
    "up:function": "cargo upgrade --manifest-path functions/counter/Cargo.toml",
    "prepare": "husky"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.258.0",
    "constructs": "^10.6.0",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@typescript/native-preview": "7.0.0-dev.20260606.1",
    "aws-cdk": "^2.1126.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.4.0",
    "eslint-plugin-import": "^2.32.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.11",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "lint-staged": {
    "{bin,lib,test}/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.14.0"
    }
  }
}
